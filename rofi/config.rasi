configuration {
    modes: "drun,run,filebrowser,window";
    font: "JetBrains Mono Nerd Font 12";
    hide-scrollbar: true;
    disable-history: true;
    cycle: true;
}

* {
    foreground: #478061;
    background: #222222;
    border-color: #478061;
}

@theme "/usr/share/rofi/themes/Arc-Dark.rasi"
